{
  "root": "card",
  "state": {},
  "elements": {
    "card": {
      "type": "Card",
      "props": {
        "title": "Heartbeat"
      },
      "children": [
        "stack"
      ]
    },
    "stack": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "alert",
        "sep1",
        "metrics_stack",
        "sep2",
        "error_section",
        "sep3",
        "status_section"
      ]
    },
    "alert": {
      "type": "Alert",
      "props": {
        "title": "Failed at 20:07 UTC",
        "message": "Heartbeat failed",
        "type": "error"
      }
    },
    "sep1": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "metrics_stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": "lg"
      },
      "children": [
        "stat_consecutive",
        "stat_success_rate"
      ]
    },
    "stat_consecutive": {
      "type": "Stat",
      "props": {
        "label": "Consecutive Failures",
        "value": "1"
      }
    },
    "stat_success_rate": {
      "type": "Stat",
      "props": {
        "label": "Success Rate",
        "value": "90%"
      }
    },
    "sep2": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "error_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "sm"
      },
      "children": [
        "error_heading",
        "error_text",
        "error_note"
      ]
    },
    "error_heading": {
      "type": "Heading",
      "props": {
        "text": "Error",
        "level": "h3"
      }
    },
    "error_text": {
      "type": "Text",
      "props": {
        "text": "Error signature looks like a truncated token-stats JSON fragment",
        "variant": "body"
      }
    },
    "error_note": {
      "type": "Text",
      "props": {
        "text": "Likely transient",
        "variant": "caption"
      }
    },
    "sep3": {
      "type": "Separator",
      "props": {
        "orientation": "horizontal"
      }
    },
    "status_section": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": "md"
      },
      "children": [
        "recovery_heading",
        "recovery_text",
        "status_badge"
      ]
    },
    "recovery_heading": {
      "type": "Heading",
      "props": {
        "text": "Recovery",
        "level": "h3"
      }
    },
    "recovery_text": {
      "type": "Text",
      "props": {
        "text": "Self-recovering this run",
        "variant": "body"
      }
    },
    "status_badge": {
      "type": "Badge",
      "props": {
        "text": "STATUS_PAGE: DEGRADED",
        "variant": "destructive"
      }
    }
  }
}
